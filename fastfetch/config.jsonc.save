{
  "logo": {
    "type": "kitty",
    "source": "/home/zei/Downloads/fas.png",
    "height": 14,
    "padding": {
      "top": 2,
      "left": 4,
    },
  },

  "display": {
    "key": {
      "width": 15,
    },
    "color": "#FF00FF",
    "separator": "~>",
  },
  "modules": [
    "break",
    {
      "type": "title",
      "format": "{6}",
    },
    "separator",
    {
      "type": "os",
      "key": "OS       ",
      "keyColor": "#00FFFF",
      "format": "Arch (Btw)",
    },
    {
      "type": "kernel",
      "key": "Kernel   ",
      "keyColor": "#00FFFF",
      "format": "{1} {2}",
    },
    {
      "type": "users",
      "key": "User     ",
      "keyColor": "#00FFFF",
      "format": "Zei",
    },
    "break",
    {
      "type": "uptime",
      "key": "Uptime   ",
      "keyColor": "#00FFFF",
    },
    {
      "type": "board",
      "key": "Device   ",
      "keyColor": "#00FFFF",
      "format": "13-Inch Zeibook Air",
    },
    {
      "type": "bios",
      "key": "Bios     ",
      "keyColor": "#00FFFF",
      "format": "{4} - {1}",
    },
    {
      "type": "cpu",
      "key": "CPU      ",
      "temp": true,
      "showPeCoreCount": true,
      "keyColor": "#00FFFF",
      "format": "{1}",
    },
    {
      "type": "gpu",
      "key": "GPU      ",
      "temp": true,
      "showPeCoreCount": true,
      "keyColor": "#00FFFF",
      "format": "{1} {2} {4}",
    },
    {
      "type": "memory",
      "key": "RAM      ",
      "temp": true,
      "showPeCoreCount": true,
      "keyColor": "#00FFFF",
      "format": "{1} / {2} {3}",
    },
    "break",
    {
      "type": "Disk",
      "key": "Disk     ", // maybe {2} or {3}
      "keyColor": "#00FFFF",
      "format": "{1} / {2} {3} ",
    },
  ],
}
